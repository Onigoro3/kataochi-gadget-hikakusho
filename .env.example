# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env自体はGitにコミットしないでください(.gitignoreで除外済み)。
#
#   cp .env.example .env   (Windowsの場合は copy .env.example .env)

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=
# 記事生成モデル。社長の希望により品質優先でSonnet 5を使用。
CLAUDE_MODEL=claude-sonnet-5

# --- はてなブログ (AtomPub API) ---
# ブログ名「型落ちガジェット比較所」
HATENA_ID=
HATENA_BLOG_DOMAIN=kataochi-gadget-hikakusho.hatenablog.com
HATENA_API_KEY=

# --- 楽天ウェブサービス(2026-07-14、Yahoo!ショッピングAPIから切り替え) ---
# Dragon(app/.env)と同じ楽天デベロッパーアプリの値を使う想定。ただし楽天の新API仕様上、
# アプリ登録時の「許可されたWebサイト」にAngelのブログドメイン(上記HATENA_BLOG_DOMAIN)を
# 追加登録しておかないとOrigin不一致で403になる点に注意(README参照)。
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=

# --- Pexels API(記事へのアイキャッチ・テーマ画像挿入用、2026-07-20追加) ---
# Dragon/Angel/Demonの3ブログで同一アカウントを共有する設計(社長方針)。
# 【任意項目】未設定でも記事生成自体は継続し、単に画像挿入だけをスキップする(config.py参照)。
PEXELS_API_KEY=
