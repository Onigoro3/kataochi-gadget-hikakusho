# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env自体はGitにコミットしないでください(.gitignoreで除外済み)。
#
#   cp .env.example .env   (Windowsの場合は copy .env.example .env)

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=
# 記事生成モデル。社長の希望により品質優先でSonnet 5を使用。
CLAUDE_MODEL=claude-sonnet-5

# --- はてなブログ (AtomPub API) ---
# ブログ名「型落ちガジェット比較所」確定済み(2026-07-13社長決定)。
# HATENA_ID(はてなアカウントID)は社長のブログ開設作業完了後に判明する値のため、
# 現時点ではプレースホルダーのまま(README「社長への依頼事項チェックリスト」参照)。
HATENA_ID=
HATENA_BLOG_DOMAIN=kataochi-gadget-hikakusho.hatenablog.com
HATENA_API_KEY=

# --- Yahoo!ショッピングAPI (Yahoo!デベロッパーネットワーク) ---
# https://e.developer.yahoo.co.jp/register/ で取得する「Client ID」。
# 社長の手作業が必要(README「社長への依頼事項チェックリスト」参照)。
YAHOO_CLIENT_ID=

# --- バリューコマース アフィリエイトID ---
# ASP審査通過(developer/tasks.md記載のWeek2〜6マイルストーン)まで空文字のままでよい。
# 空の間は通常商品URLのままリンクを張る(コード側で自動的に処理される)。
VC_AFFILIATE_ID=
